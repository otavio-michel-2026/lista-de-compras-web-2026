@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Produtos";
}

@model List<ListarProdutoViewModel>;

<a class="btn btn-outline-primary rounded-pill px-4 mb-3" asp-action="Cadastrar">Cadastrar Novo</a>

@if (TempData[" MensagemErro"] is string mensagemErro)
{
    <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
        @mensagemErro
    </div>
}

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Nenhum produto cadastrado.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle bg-white">
            <thead class="table-primary">
                <tr>
                    <th>ID</th>
                    <th>Nome</th>
                    <th>Categoria</th>
                    <th>Unidade de medida</th>
                    <th>Preço</th>
                    <th>Açoes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (ListarProdutoViewModel p in Model)
                {
                    <tr>
                        <td>@p.Id</td>
                        <td>@p.Nome</td>
                        <td>@p.CategoriaNome</td>
                        <td>@p.UnidadeDeMedida</td>
                        <td>@p.Preco</td>
                        <td>
                            <div class="d-flex gap-2">
                                <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Editar" asp-route-id="@p.Id">Editar</a>
                                <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Excluir" asp-route-id="@p.Id">Excluir</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
