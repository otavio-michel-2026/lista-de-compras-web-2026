@{
    Layout = "_Layout";
    ViewBag.Titulo = "Exclusão de Produto";
}

@model ExcluirProdutoViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Excluir" asp-route-id="@Model.Id" method="post">
    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Deseja realmente excluir este produto?
    </div>

    <div class="mb-3">
        <label asp-for="Nome" class="form-label fw-semibold text-primary text-uppercase small">Nome</label>
        <input asp-for="Nome" type="text" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label asp-for="CategoriaNome" class="form-label fw-semibold text-primary text-uppercase small">Categoria</label>
        <input asp-for="CategoriaNome" type="text" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label asp-for="UnidadeDeMedida" class="form-label fw-semibold text-primary text-uppercase small">Unidade de Medida</label>
        <input asp-for="UnidadeDeMedida" type="text" class="form-control" disabled>
    </div>

    <div class="mb-3">
        <label asp-for="Preco" class="form-label fw-semibold text-primary text-uppercase small">Preço</label>
        <input asp-for="Preco" type="number" step="0.01" class="form-control" disabled>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
        <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
    </div>
</form>
