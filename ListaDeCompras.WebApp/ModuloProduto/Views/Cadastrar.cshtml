@{
    Layout = "_Layout";
    ViewBag.Titulo = "Cadastro de Produto";
}

@model CadastrarProdutoViewModel;

@if (Model.Categorias == null || Model.Categorias.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3 mx-auto" style="max-width: 620px;" role="alert">
        Cadastre uma categoria antes de cadastrar produtos.
    </div>
}

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Cadastrar" method="post">
    <div class="mb-3">
        <label asp-for="Nome" class="form-label fw-semibold text-primary text-uppercase small">Nome</label>
        <input asp-for="Nome" type="text" class="form-control">
        <span asp-validation-for="Nome" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CategoriaId" class="form-label fw-semibold text-primary text-uppercase small">Categoria</label>
        <select asp-for="CategoriaId" class="form-select">
            <option value="">Selecione uma categoria</option>
            @foreach (OpcaoCategoriaViewModel categoria in Model.Categorias ?? new List<OpcaoCategoriaViewModel>())
            {
                <option value="@categoria.Id">@categoria.Etiqueta</option>
            }
        </select>
        <span asp-validation-for="CategoriaId" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="UnidadeDeMedida" class="form-label fw-semibold text-primary text-uppercase small">Unidade de Medida</label>
        <input asp-for="UnidadeDeMedida" type="text" class="form-control">
        <span asp-validation-for="UnidadeDeMedida" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Preco" class="form-label fw-semibold text-primary text-uppercase small">Preço</label>
        <input asp-for="Preco" type="number" step="0.01" class="form-control">
        <span asp-validation-for="Preco" class="text-danger small fw-semibold"></span>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
        @if (Model.Categorias == null || Model.Categorias.Count == 0)
        {
            <button class="btn btn-primary rounded-pill px-4" type="submit" disabled>Confirmar</button>
        }
        else
        {
            <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
        }
    </div>
</form>
