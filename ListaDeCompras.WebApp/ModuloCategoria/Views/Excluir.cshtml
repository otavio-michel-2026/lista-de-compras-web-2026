@{
    Layout = "_Layout";
    ViewBag.Titulo = "Exclusão de Categoria";
}

@model CategoriaViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Excluir" asp-route-id="@Model.Id" method="post">

    <div class="alert alert-primary border-start border-primary border-2 rounded-3" role="alert">
        Tem certeza que deseja excluir esta categoria?
    </div>

    <dl class="row mb-0">
        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">ID</dt>
        <dd class="col-sm-8">@Model.Id</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Etiqueta</dt>
        <dd class="col-sm-8">@Model.Nome</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Cor</dt>
        <dd class="col-sm-8">@Model.Cor</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Dias de Empréstimo</dt>
        <dd class="col-sm-8">@Model.QtdProduto</dd>
    </dl>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
        <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
    </div>
</form>
