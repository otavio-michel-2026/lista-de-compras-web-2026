@{
    ViewBag.Titulo = "Adicionar item à lista de compras";
}

@model GerenciarItemViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="AdicionarItem" asp-route-id="@Model.Id" method="post">
    <input asp-for="Id" type="hidden">
    
    <div class="mb-3">
        <label asp-for="ProdutoId" class="form-label fw-semibold text-primary text-uppercase small">Produto</label>
        <select asp-for="ProdutoId" asp-items="@Model.Produtos" type="text" class="form-control">
            <option value="">Selecione um produto</option>
        </select>
        <span asp-validation-for="ProdutoId" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Quantidade" class="form-label fw-semibold text-primary text-uppercase small">Quantidade</label>
        <input asp-for="Quantidade" type="number" step="0.01" min="0.01" class="form-control">
        <span asp-validation-for="Quantidade" class="text-danger small fw-semibold"></span>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="VisualizarItens" asp-route-id="@Model.Id">Voltar</a>
        @if (Model.Produtos.Count == 0)
        {
            <button class="btn btn-primary rounded-pill px-4" type="submit" disabled>Confirmar</button>
        }
        else
        {
            <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
        }
    </div>
</form>

